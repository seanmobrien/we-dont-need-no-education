{
  "name": "@compliance-theater/send-api-request",
  "version": "0.1.0",
  "private": true,
  "description": "API request utilities for the Title IX Victim Advocacy Platform",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "workspace-source": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "workspace-source": "./src/*.ts",
      "default": "./dist/*.js"
    }
  },
  "engines": {
    "node": ">=22.0.0",
    "yarn": ">=1.22.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "yarn run build:typescript",
    "build:publish": "yarn run build && yarn pack --out ./dist/@compliance-theater-send-api-request.tgz",
    "build:typescript": "echo 'Building lib/send-api-request...' && tsc -b tsconfig.json && printf '\u001b[1;32mBuild complete: @compliance-theater/send-api-request.\u001b[0m\n' || (printf '\u001b[31mBuild failed: @compliance-theater/send-api-request.\u001b[0m\n' >&2; exit 1)",
    "test": "jest",
    "lint": "echo 'Linting lib-send-api-request...'",
    "build:clean": "rimraf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@auth/core": "0.41.1",
    "@compliance-theater/env": "workspace:*",
    "@compliance-theater/logger": "workspace:*",
    "@compliance-theater/redis": "workspace:*",
    "@compliance-theater/typescript": "workspace:*",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/api-logs": "0.57.2",
    "fast-deep-equal": "^3.1.3",
    "mitt": "^3.0.1",
    "next": "15.5.12",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "redis": ">=5.5.6"
  },
  "devDependencies": {
    "@jest/globals": "^29.0.0",
    "@types/node": "25.2.3",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "jest": "^30.0.5",
    "rimraf": "^6.1.2",
    "ts-jest": "^30.0.0",
    "typescript": "^5"
  }
}
