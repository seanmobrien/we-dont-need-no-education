{
  "name": "@compliance-theater/fetch",
  "version": "0.1.0",
  "private": true,
  "description": "Runtime-aware fetch package for node and browser/edge",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "workspace-source": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "workspace-source": "./src/*.ts",
      "default": "./dist/*.js"
    }
  },
  "engines": {
    "node": ">=22.0.0",
    "yarn": ">=4.12.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "add": "yarn workspace @compliance-theater/fetch add ",
    "build": "yarn run build:typescript",
    "build:typescript": "echo 'Building @compliance-theater/fetch...' && tsc -b tsconfig.json && printf '\u001b[1;32mBuild complete: @compliance-theater/fetch.\u001b[0m\\n' || (printf '\u001b[31mBuild failed: @compliance-theater/fetch.\u001b[0m\\n' >&2; exit 1)",
    "build:publish": "yarn run build && yarn pack --out ./dist/@compliance-theater-fetch.tgz",
    "test": "jest",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx --config ../../eslint.config.mjs",
    "build:clean": "rimraf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@compliance-theater/redis": "workspace:*",
    "@compliance-theater/types": "workspace:*",
    "@compliance-theater/typescript": "workspace:*",
    "got": "^14.4.9",
    "lru-cache": "^11.0.2"
  },
  "devDependencies": {
    "@jest/globals": "^30.0.0",
    "@jest/transform": "^30.0.0",
    "@jest/types": "^30.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "25.2.3",
    "jest": "^30.0.5",
    "jest-util": "^30.0.0",
    "rimraf": "^6.1.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
