{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "outDir": "./dist",
        "rootDir": "./src",
        "composite": true,
        "declaration": true,
        "declarationMap": true,
        "baseUrl": ".",
        "noEmit": false,
        "types": [
            "node",
            "jest"
        ]
    },
    "include": [
        "src/**/*.d.ts",
        "src/**/*.ts",
        "src/**/*.tsx"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ],
    "references": [
        {
            "path": "../lib-redis"
        },
        {
            "path": "../lib-types"
        },
        {
            "path": "../lib-typescript"
        }
    ]
}