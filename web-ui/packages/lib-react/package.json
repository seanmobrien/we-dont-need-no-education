{
  "name": "@compliance-theater/react",
  "version": "0.1.0",
  "private": true,
  "description": "React utilities and hooks for the Title IX Victim Advocacy Platform",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "workspace-source": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "workspace-source": "./src/errors/index.ts",
      "default": "./dist/errors/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "workspace-source": "./src/hooks/index.ts",
      "default": "./dist/hooks/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "workspace-source": "./src/*.ts",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.0.0",
    "yarn": ">=1.22.0"
  },
  "scripts": {
    "build": "yarn run build:typescript",
    "build:publish": "yarn run build && yarn pack --out ./dist/@compliance-theater-react.tgz",
    "build:typescript": "echo 'Building lib/react typescript...' && tsc -b tsconfig.json && printf '\\u001b[1;32mBuild complete: @compliance-theater/react.\\u001b[0m\\n' || (printf '\\u001b[31mBuild failed: @compliance-theater/react.\\u001b[0m\\n' >&2; exit 1)",
    "test": "jest",
    "build:clean": "rimraf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@compliance-theater/env": "workspace:*",
    "@compliance-theater/logger": "workspace:*",
    "@compliance-theater/types": "workspace:*",
    "@compliance-theater/typescript": "workspace:*"
  },
  "peerDependencies": {
    "@auth/core": "0.41.1",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/api-logs": "0.57.2",
    "fast-deep-equal": "^3.1.3",
    "mitt": "^3.0.1",
    "next": "15.5.12",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.0.0",
    "@types/node": "25.2.3",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "jest": "^30.0.5",
    "rimraf": "^6.1.2",
    "ts-jest": "^30.0.0",
    "typescript": "^5"
  }
}
