{
  "name": "@compliance-theater/types",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript type definitions for AI and chat functionality",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.0.0",
    "yarn": ">=4.12.0"
  },
  "scripts": {
    "add": "yarn workspace @compliance-theater/types add ",
    "build": "yarn build:typescript",
    "build:publish": "yarn build && yarn pack --out ./dist/@compliance-theater-types.tgz",
    "build:typescript": "echo 'Building lib/types...' && tsc -b tsconfig.json && printf '\\u001b[1;32mBuild complete: @compliance-theater/types.\\u001b[0m\\n' || (printf '\\u001b[31mBuild failed: @compliance-theater/types.\\u001b[0m\\n' >&2; exit 1)",
    "test": "jest",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx --config ../../eslint.config.mjs",
    "build:clean": "rimraf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@auth/core": "0.41.1",
    "@react-native/virtualized-lists": "npm:0.84.0",
    "ai": "^5.0.23",
    "awilix": "^13.0.0",
    "got": "^14.4.9",
    "mitt": "^3.0.1",
    "next": "15.5.12",
    "next-auth": "^5.0.0-beta.30",
    "postgres": "^3.4.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "ts-pattern": "^5.5.2",
    "zod": "^3.25.76",
    "zodex": "^3.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.0.5",
    "@jest/transform": "^30.0.0",
    "@jest/types": "^30.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "25.2.3",
    "@types/react": "19.2.4",
    "@types/react-dom": "19.2.3",
    "jest": "^30.0.5",
    "jest-util": "^30.0.0",
    "react-native": "^0.84.0",
    "rimraf": "^6.1.2",
    "ts-jest": "^30.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.9.3"
  }
}
