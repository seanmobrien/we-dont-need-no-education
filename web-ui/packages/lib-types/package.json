{
  "name": "@compliance-theater/types",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript type definitions for AI and chat functionality",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "workspace-source": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./lib/ai": {
      "types": "./dist/lib/ai/index.d.ts",
      "workspace-source": "./src/lib/ai/index.ts",
      "default": "./dist/lib/ai/index.js"
    },
    "./lib/ai/*": {
      "types": "./dist/lib/ai/*.d.ts",
      "workspace-source": "./src/lib/ai/*.ts",
      "default": "./dist/lib/ai/*.js"
    },
    "./lib/ai/core": {
      "types": "./dist/lib/ai/core/index.d.ts",
      "workspace-source": "./src/lib/ai/core/index.ts",
      "default": "./dist/lib/ai/core/index.js"
    },
    "./lib/ai/core/*": {
      "types": "./dist/lib/ai/core/*.d.ts",
      "workspace-source": "./src/lib/ai/core/*.ts",
      "default": "./dist/lib/ai/core/*.js"
    },
    "./lib/ai/chat": {
      "types": "./dist/lib/ai/chat/index.d.ts",
      "workspace-source": "./src/lib/ai/chat/index.ts",
      "default": "./dist/lib/ai/chat/index.js"
    },
    "./lib/ai/chat/*": {
      "types": "./dist/lib/ai/chat/*.d.ts",
      "workspace-source": "./src/lib/ai/chat/*.ts",
      "default": "./dist/lib/ai/chat/*.js"
    },
    "./lib/ai/message-structure-preservation": {
      "types": "./dist/lib/ai/message-structure-preservation.d.ts",
      "workspace-source": "./src/lib/ai/message-structure-preservation.ts",
      "default": "./dist/lib/ai/message-structure-preservation.js"
    },
    "./dependency-injection": {
      "types": "./dist/dependency-injection/index.d.ts",
      "workspace-source": "./src/dependency-injection/index.ts",
      "default": "./dist/dependency-injection/index.js"
    },
    "./dependency-injection/*": {
      "types": "./dist/dependency-injection/*.d.ts",
      "workspace-source": "./src/dependency-injection/*.ts",
      "default": "./dist/dependency-injection/*.js"
    },
    "./ai-sdk": {
      "types": "./dist/ai-sdk/index.d.ts",
      "workspace-source": "./src/ai-sdk/index.ts",
      "default": "./dist/ai-sdk/index.js"
    },
    "./ai-sdk/*": {
      "types": "./dist/ai-sdk/*.d.ts",
      "workspace-source": "./src/ai-sdk/*.ts",
      "default": "./dist/ai-sdk/*.js"
    },
    "./lib/nextjs": {
      "types": "./dist/lib/nextjs/index.d.ts",
      "workspace-source": "./src/lib/nextjs/index.ts",
      "default": "./dist/lib/nextjs/index.js"
    },
    "./lib/nextjs/guards": {
      "types": "./dist/lib/nextjs/guards.d.ts",
      "workspace-source": "./src/lib/nextjs/guards.ts",
      "default": "./dist/lib/nextjs/guards.js"
    },
    "./lib/nextjs/types": {
      "types": "./dist/lib/nextjs/types/index.d.ts",
      "workspace-source": "./src/lib/nextjs/types/index.ts",
      "default": "./dist/lib/nextjs/types/index.js"
    },
    "./lib/nextjs/types/*": {
      "types": "./dist/lib/nextjs/types/*.d.ts",
      "workspace-source": "./src/lib/nextjs/types/*.ts",
      "default": "./dist/lib/nextjs/types/*.js"
    },
    "./lib/nextjs/get-header-value": {
      "types": "./dist/lib/nextjs/get-header-value.d.ts",
      "workspace-source": "./src/lib/nextjs/get-header-value.ts",
      "default": "./dist/lib/nextjs/get-header-value.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "workspace-source": "./src/*.ts",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.0.0",
    "yarn": ">=1.22.0"
  },
  "scripts": {
    "add": "yarn workspace @compliance-theater/types add ",
    "build": "yarn build:typescript",
    "build:publish": "yarn build && yarn pack --out ./dist/@compliance-theater-types.tgz",
    "build:typescript": "echo 'Building lib/types...' && tsc -b tsconfig.json && printf '\\u001b[1;32mBuild complete: @compliance-theater/types.\\u001b[0m\\n' || (printf '\\u001b[31mBuild failed: @compliance-theater/types.\\u001b[0m\\n' >&2; exit 1)",
    "test": "jest",
    "lint": "echo 'Linting lib-types...'",
    "build:clean": "rimraf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@auth/core": "0.41.1",
    "@react-native/virtualized-lists": "npm:0.84.0",
    "ai": "^5.0.23",
    "awilix": "^13.0.0",
    "got": "^14.4.9",
    "mitt": "^3.0.1",
    "next": "15.5.12",
    "next-auth": "^5.0.0-beta.30",
    "postgres": "^3.4.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "ts-pattern": "^5.5.2",
    "zod": "^3.25.76",
    "zodex": "^3.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.0.0",
    "@jest/transform": "^30.0.0",
    "@jest/types": "^30.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "19.2.4",
    "@types/react-dom": "19.2.3",
    "jest": "^30.0.5",
    "jest-util": "^30.0.0",
    "react-native": "^0.84.0",
    "rimraf": "^6.1.2",
    "ts-jest": "^30.0.0",
    "typescript": "^5"
  }
}
