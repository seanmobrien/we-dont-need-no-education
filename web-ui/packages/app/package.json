{
  "name": "@compliance-theater/app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "add": "yarn workspace @compliance-theater/app add -D ",
    "dev": "next dev",
    "build": "next typegen && cross-env NODE_OPTIONS='--max-old-space-size=4096' tsc -p tsconfig.json --noEmit",
    "build:typescript": "echo 'Building Web Application...' && next typegen && cross-env NODE_OPTIONS='--max-old-space-size=4096' tsc -p tsconfig.json --noEmit && printf '\u001b[1;32mBuild complete: Web Application.\u001b[0m\n' || (printf '\u001b[31mBuild failed: Web Application.\u001b[0m\n' >&2; exit 1)",
    "build:publish": "cross-env NODE_OPTIONS='--max-old-space-size=4096' WORKSPACE_SOURCE_IMPORTS=1 next build",
    "build:debug": "next typegen && cross-env NODE_OPTIONS='--max-old-space-size=4096' next build --profile --debug",
    "build:clean": "rimraf .next dist tsconfig.tsbuildinfo",
    "debug": "cross-env NODE_OPTIONS='--inspect' next dev",
    "test": "jest",
    "test:serial": "jest --runInBand",
    "test:concurrency-stress": "jest --maxWorkers=8 --maxConcurrency=10",
    "test:e2e": "playwright test --project=chromium-safe --project=firefox-safe",
    "test:e2e:safe": "playwright test --project=chromium-safe --project=firefox-safe --project=webkit-safe",
    "test:e2e:all": "cross-env RUN_ALL_TESTS=true playwright test",
    "test:e2e:mutation": "cross-env ENABLE_DATA_MUTATION_TESTS=true playwright test --project=chromium-mutation --project=firefox-mutation",
    "test:e2e:headed": "playwright test --headed --project=chromium-safe",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug --project=chromium-safe",
    "test:e2e:chromium": "playwright test --project=chromium-safe",
    "test:e2e:firefox": "playwright test --project=firefox-safe",
    "test:e2e:webkit": "playwright test --project=webkit-safe",
    "test:e2e:report": "playwright show-report",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "vercel-build": "yarn run build:publish",
    "test:timeout": "timeout 600 jest",
    "test:long": "jest --testTimeout=60000"
  },
