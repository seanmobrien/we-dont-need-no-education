{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "tsBuildInfoFile": "./tsconfig.tsbuildinfo",
    "baseUrl": ".",
    "types": [
      "node",
      "jest"
    ],
    "noEmit": false,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ],
  "references": [
    {
      "path": "../lib-after"
    },
    {
      "path": "../lib-env"
    },
    {
      "path": "../lib-logger"
    },
    {
      "path": "../lib-typescript"
    },
    {
      "path": "../lib-types"
    }
  ]
}