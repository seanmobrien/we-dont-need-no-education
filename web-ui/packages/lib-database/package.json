{
  "name": "@compliance-theater/database",
  "version": "0.1.0",
  "private": true,
  "description": "Database layer with Drizzle ORM and PostgreSQL driver for the Title IX Victim Advocacy Platform",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "workspace-source": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./driver": {
      "types": "./dist/driver/index.d.ts",
      "workspace-source": "./src/driver/index.ts",
      "default": "./dist/driver/index.js"
    },
    "./orm": {
      "types": "./dist/orm/index.d.ts",
      "workspace-source": "./src/orm/index.ts",
      "default": "./dist/orm/index.js"
    },
    "./schema": {
      "types": "./dist/drizzle/schema.d.ts",
      "workspace-source": "./src/drizzle/schema.ts",
      "default": "./dist/drizzle/schema.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "workspace-source": "./src/*.ts",
      "default": "./dist/*.js"
    }
  },
  "engines": {
    "node": ">=22.0.0",
    "yarn": ">=1.22.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "yarn run build:typescript",
    "build:typescript": "echo 'Building @compliance-theater/database...' && tsc -b tsconfig.json && printf '\u001b[1;32mBuild complete: @compliance-theater/database.\u001b[0m\n' || (printf '\u001b[31mBuild failed: @compliance-theater/database.\u001b[0m\n' >&2; exit 1)",
    "build:publish": "yarn run build && yarn pack --out ./dist/@compliance-theater-database.tgz",
    "drizzle-generate": "drizzle-kit generate --config=drizzle.config.ts",
    "drizzle-migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "drizzle-studio": "drizzle-kit studio --config=drizzle.config.ts",
    "test": "jest",
    "lint": "echo 'Linting lib-database...'",
    "build:clean": "rimraf .next dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@compliance-theater/after": "workspace:*",
    "@compliance-theater/env": "workspace:*",
    "@compliance-theater/logger": "workspace:*",
    "@compliance-theater/redis": "workspace:*",
    "@compliance-theater/types": "workspace:*",
    "@compliance-theater/typescript": "workspace:*",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/api-logs": "0.57.2",
    "drizzle-orm": "^0.44.1",
    "expo": ">=14.0.0",
    "expo-sqlite": ">=14.0.0",
    "gel": ">=2",
    "knex": "*",
    "kysely": "*",
    "mitt": "^3.0.1",
    "mysql2": ">=2",
    "pg": ">=8",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.5",
    "react-native": "*",
    "redis": ">=5.5.6",
    "sql.js": ">=1",
    "sqlite3": ">=5"
  },
  "devDependencies": {
    "@jest/globals": "^29.0.0",
    "@types/node": "25.2.3",
    "@types/pg": "^8.15.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-kit": "^0.31.1",
    "jest": "^30.0.5",
    "rimraf": "^6.1.2",
    "ts-jest": "^30.0.0",
    "typescript": "^5"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
