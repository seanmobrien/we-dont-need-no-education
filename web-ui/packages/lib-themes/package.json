{
  "name": "@compliance-theater/themes",
  "version": "0.1.0",
  "private": true,
  "description": "Theme and styling utilities for the Title IX Victim Advocacy Platform",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "workspace-source": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./themes": {
      "types": "./dist/themes/index.d.ts",
      "workspace-source": "./src/themes/index.ts",
      "default": "./dist/themes/index.js"
    },
    "./styles": {
      "types": "./dist/styles/index.d.ts",
      "workspace-source": "./src/styles/index.ts",
      "default": "./dist/styles/index.js"
    },
    "./provider": {
      "types": "./dist/themes/provider.d.ts",
      "workspace-source": "./src/themes/provider.ts",
      "default": "./dist/themes/provider.js"
    },
    "./components/theme-selector": {
      "types": "./dist/themes/theme-selector.d.ts",
      "workspace-source": "./src/themes/theme-selector.tsx",
      "default": "./dist/themes/theme-selector.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "workspace-source": "./src/*.ts",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.0.0",
    "yarn": ">=1.22.0"
  },
  "scripts": {
    "build": "yarn run build:typescript",
    "build:typescript": "echo 'Building lib/themes...' && tsc -b tsconfig.json && printf '\u001b[1;32mBuild complete: @compliance-theater/themes.\u001b[0m\n' || (printf '\u001b[31mBuild failed: @compliance-theater/themes.\u001b[0m\n' >&2; exit 1)",
    "build:publish": "yarn run build && yarn pack --out ./dist/@compliance-theater-themes.tgz",
    "test": "jest",
    "lint": "echo 'Linting lib-themes...'",
    "build:clean": "rimraf .next dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@compliance-theater/logger": "workspace:*",
    "@compliance-theater/types": "workspace:*",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.3.6",
    "@mui/material": "^7.3.6"
  },
  "devDependencies": {
    "@jest/globals": "^29.0.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@types/node": "25.2.3",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "jest": "^30.0.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rimraf": "^6.1.2",
    "ts-jest": "^30.0.0",
    "typescript": "^5"
  },
  "peerDependencies": {
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/api-logs": "0.57.2",
    "mitt": "^3.0.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
