{
  "name": "@compliance-theater/themes",
  "version": "0.1.0",
  "private": true,
  "description": "Theme and styling utilities for the Title IX Victim Advocacy Platform",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.0.0",
    "yarn": ">=4.12.0"
  },
  "scripts": {
    "add": "yarn workspace @compliance-theater/themes add ",
    "build": "yarn run build:typescript",
    "build:typescript": "echo 'Building @compliance-theater/themes...' && tsc -b tsconfig.json && printf '\u001b[1;32mBuild complete: @compliance-theater/themes.\u001b[0m\n' || (printf '\u001b[31mBuild failed: @compliance-theater/themes.\u001b[0m\n' >&2; exit 1)",
    "build:publish": "yarn run build && yarn pack --out ./dist/@compliance-theater-themes.tgz",
    "test": "jest",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx --config ../../eslint.config.mjs",
    "build:clean": "rimraf .next dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@auth/core": "0.41.1",
    "@compliance-theater/logger": "workspace:*",
    "@compliance-theater/types": "workspace:*",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.3.6",
    "@mui/material": "^7.3.6",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/api-logs": "0.57.2",
    "@react-native/virtualized-lists": "npm:0.84.0",
    "got": "^14.4.9",
    "mitt": "^3.0.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^3.25.76",
    "zodex": "^3.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.0.0",
    "@jest/transform": "^30.0.0",
    "@jest/types": "^30.0.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "25.2.3",
    "@types/react": "19.2.4",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "jest": "^30.0.5",
    "jest-util": "^30.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-native": "^0.84.0",
    "rimraf": "^6.1.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
