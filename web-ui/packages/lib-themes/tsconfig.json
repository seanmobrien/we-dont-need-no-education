{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "tsBuildInfoFile": "./tsconfig.tsbuildinfo",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "baseUrl": ".",
    "types": [
      "node",
      "jest"
    ],
    "noEmit": false,
    "jsx": "react-jsx",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ]
  },
  "include": [
    "src/**/*.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "**/__tests__/**",
    "**/__mocks__/**",
    "dist"
  ],
  "references": [
    {
      "path": "../lib-logger"
    },
    {
      "path": "../lib-types"
    }
  ]
}