{
  "name": "@compliance-theater/env",
  "version": "0.1.0",
  "private": true,
  "description": "Environment variable utilities with Zod validation for the Title IX Victim Advocacy Platform",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "engines": {
    "node": ">=22.0.0",
    "yarn": ">=4.12.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "add": "yarn workspace @compliance-theater/env add ",
    "build": "yarn run build:typescript",
    "build:typescript": "echo 'Building @compliance-theater/env...' && tsc -b tsconfig.json && printf '\u001b[1;32mBuild complete: @compliance-theater/env.\u001b[0m\n' || (printf '\u001b[31mBuild failed: @compliance-theater/env.\u001b[0m\n' >&2; exit 1)",
    "build:publish": "yarn run build && yarn pack --out ./dist/@compliance-theater-env.tgz",
    "test": "jest",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx --config ../../eslint.config.mjs",
    "build:clean": "rimraf .next dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@auth/core": "0.41.1",
    "@compliance-theater/logger": "workspace:*",
    "@compliance-theater/types": "workspace:*",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/api-logs": "0.57.2",
    "@react-native/virtualized-lists": "npm:0.84.0",
    "got": "^14.4.9",
    "mitt": "^3.0.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "redis": ">=5.5.6",
    "zodex": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@jest/globals": "^30.0.0",
    "@jest/transform": "^30.0.0",
    "@jest/types": "^30.0.0",
    "@playwright/test": "^1.55.0",
    "@tanstack/react-query-devtools": "5.91.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.16",
    "@types/node": "25.2.3",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.15.2",
    "@types/react": "19.2.4",
    "@types/react-dom": "19.2.3",
    "@types/react-resizable": "^3.0.8",
    "@types/uuid": "^10.0.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "canvas": "^3.2.0",
    "cross-env": "^10.0.0",
    "dotenv": "^16.5.0",
    "drizzle-kit": "^0.31.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.12",
    "eslint-config-prettier": "^10.1.5",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.0.5",
    "jest-environment-jsdom": "^30.0.5",
    "jest-mock-extended": "^4.0.0-beta1",
    "jest-util": "^30.0.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.3",
    "rimraf": "^6.1.2",
    "ts-jest": "^30.0.0",
    "undici": "^7.16.0",
    "web-streams-polyfill": "^4.2.0"
  }
}
