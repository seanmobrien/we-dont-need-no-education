{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "declaration": true,
    "tsBuildInfoFile": "./tsconfig.tsbuildinfo",
    "declarationMap": true,
    "baseUrl": ".",
    "paths": {},
    "noEmit": false,
    "types": [
      "node",
      "jest"
    ],
  },
  "include": [
    "src/**/*.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "**/__tests__/**",
    "**/__mocks__/**",
    "dist",
  ],
  "references": [
    {
      "path": "../lib-logger"
    },
    {
      "path": "../lib-env"
    }
  ]
}