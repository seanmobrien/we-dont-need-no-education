{
  "name": "@compliance-theater/typescript",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript utility types and helpers",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "workspace-source": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./singleton-provider": {
      "types": "./dist/singleton-provider/index.d.ts",
      "workspace-source": "./src/singleton-provider/index.ts",
      "default": "./dist/singleton-provider/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "workspace-source": "./src/*.ts",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.0.0",
    "yarn": ">=1.22.0"
  },
  "scripts": {
    "build": "yarn run build:typescript",
    "build:publish": "yarn run build && yarn pack --out ./dist/@compliance-theater-typescript.tgz",
    "build:typescript": "echo 'Building lib/typescript typescript...' && tsc -b tsconfig.json && printf '\u001b[1;32mBuild complete: @compliance-theater/typescript.\u001b[0m\n' || (printf '\u001b[31mBuild failed: @compliance-theater/typescript.\u001b[0m\n' >&2; exit 1)",
    "test": "jest",
    "lint": "echo 'Linting lib-typescript...'",
    "build:clean": "rimraf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@compliance-theater/env": "workspace:*",
    "@compliance-theater/logger": "workspace:*",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/api-logs": "0.57.2",
    "mitt": "^3.0.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "redis": ">=5.5.6",
    "uuid": "^11.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@jest/globals": "^29.0.0",
    "@types/node": "25.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "jest": "^30.0.5",
    "rimraf": "^6.1.2",
    "ts-jest": "^30.0.0",
    "typescript": "^5"
  }
}
