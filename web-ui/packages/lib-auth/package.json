{
  "name": "@compliance-theater/auth",
  "version": "0.1.0",
  "private": true,
  "description": "Authentication and authorization library for the Title IX Victim Advocacy Platform",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "engines": {
    "node": ">=22.0.0",
    "yarn": ">=4.12.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "add": "yarn workspace @compliance-theater/auth add ",
    "build": "yarn run build:typescript",
    "build:typescript": "echo 'Building @compliance-theater/auth...' && tsc -b tsconfig.json && printf '\u001b[1;32mBuild complete: @compliance-theater/auth.\u001b[0m\n' || (printf '\u001b[31mBuild failed: @compliance-theater/auth.\u001b[0m\n' >&2; exit 1)",
    "build:publish": "yarn run build && yarn pack --out ./dist/@compliance-theater-auth.tgz",
    "test": "jest",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx --config ../../eslint.config.mjs",
    "build:clean": "rimraf .next dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.4.1",
    "@compliance-theater/database": "workspace:*",
    "@compliance-theater/env": "workspace:*",
    "@compliance-theater/logger": "workspace:*",
    "@compliance-theater/nextjs": "workspace:*",
    "@compliance-theater/react": "workspace:*",
    "@compliance-theater/redis": "workspace:*",
    "@compliance-theater/types": "workspace:*",
    "@compliance-theater/typescript": "workspace:*",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@keycloak/keycloak-admin-client": "^26.3.4",
    "@mui/icons-material": "^7.3.6",
    "@mui/material": "^7.3.6",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/api-logs": "0.57.2",
    "@redis/client": ">=5.5.6",
    "@tanstack/react-query": "5.90.21",
    "@toolpad/core": "^0.15.0",
    "google-auth-library": "^9.15.1",
    "got": "^14.4.9",
    "jose": "^6.1.3",
    "lru-cache": "^11.0.2",
    "next-auth": "^5.0.0-beta.30",
    "node-html-parser": "^7.0.1",
    "react-native": "^0.84.0",
    "tough-cookie": "^6.0.0"
  },
  "peerDependencies": {
    "next": "^15.5.12",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@jest/globals": "^30.0.5",
    "@keycloak/keycloak-admin-client": "^26.3.4",
    "@mui/icons-material": "^7.3.6",
    "@mui/material": "^7.3.6",
    "@swc/core": "^1.13.5",
    "@swc/jest": "^0.2.39",
    "@tanstack/react-query": "5.90.21",
    "@testing-library/jest-dom": "^6.6.4",
    "@toolpad/core": "^0.15.0",
    "@types/jest": "^30.0.0",
    "@types/react": "19.2.4",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "google-auth-library": "^9.15.1",
    "got": "^14.4.9",
    "jest": "^30.0.5",
    "node-html-parser": "^7.0.1",
    "openid-client": "^6.8.0",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3"
  }
}
