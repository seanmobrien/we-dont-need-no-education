{
  "name": "compliance-theater",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@4.12.0",
  "workspaces": [
    "packages/app",
    "packages/lib-logger",
    "packages/lib-env",
    "packages/lib-typescript",
    "packages/lib-redis",
    "packages/lib-after",
    "packages/lib-database",
    "packages/lib-auth",
    "packages/lib-nextjs",
    "packages/lib-react",
    "packages/lib-themes",
    "packages/lib-types",
    "packages/lib-feature-flags",
    "packages/lib-fetch",
    "packages/lib-send-api-request",
    "submodules/json-viewer/packages",
    "submodules/sce"
  ],
  "scripts": {
    "add": "turbo run add --filter='@compliance-theater/*' ",
    "dev": "turbo run dev --filter='@compliance-theater/app...'",
    "debug": "turbo run debug --filter='@compliance-theater/app...'",
    "build": "turbo run build --filter='@compliance-theater/app...' --continue=dependencies-successful",
    "build:partial": "turbo run build --filter='@compliance-theater/app...' --continue=dependencies-successful",
    "build:typescript": "turbo run build:typescript --filter='@compliance-theater/app...' --continue=dependencies-successful",
    "build:typescript:partial": "turbo run build:typescript --filter='@compliance-theater/app...' --continue=dependencies-successful",
    "build:publish": "cross-env YARN_IGNORE_PATH=1 turbo run build:publish --filter='@compliance-theater/app...'",
    "build:clean": "turbo run build:clean --filter='@compliance-theater/app...'",
    "test": "turbo run test --filter='@compliance-theater/app...' -- ",
    "test:coverage": "turbo run test --filter='@compliance-theater/app...'  --continue=dependencies-successful -- --coverage",
    "test:fast": "turbo run test --filter='@compliance-theater/app...'  --continue=dependencies-successful  -- ",
    "test:unit": "turbo run test:unit --filter='@compliance-theater/app...' -- --coverage",
    "test:e2e": "turbo run test:e2e --filter='@compliance-theater/app...'  -- ",
    "lint": "turbo run lint --filter='@compliance-theater/app...'"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@eslint/js": "^9.39.1",
    "@jest/globals": "^30.0.5",
    "@playwright/test": "^1.55.0",
    "@swc/core": "^1.13.5",
    "@swc/jest": "^0.2.39",
    "@tanstack/react-query": "5.90.21",
    "@tanstack/react-query-devtools": "5.91.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "25.2.3",
    "@types/react": "19.2.4",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "canvas": "^3.2.0",
    "cross-env": "^10.0.0",
    "dotenv": "^16.5.0",
    "drizzle-kit": "^0.31.1",
    "eslint": "^9.39.3",
    "eslint-config-next": "15.5.12",
    "eslint-config-prettier": "^10.1.5",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.0.5",
    "jest-environment-jsdom": "^30.0.5",
    "jest-mock-extended": "^4.0.0-beta1",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.3",
    "rimraf": "^6.1.2",
    "turbo": "^2.8.3",
    "typescript": "^5.9.3",
    "undici": "^7.16.0",
    "web-streams-polyfill": "^4.2.0"
  },
  "dependencies": {
    "@auth/core": "0.41.1",
    "@compliance-theater/after": "workspace:*",
    "@compliance-theater/app": "workspace:*",
    "@compliance-theater/auth": "workspace:*",
    "@compliance-theater/database": "workspace:*",
    "@compliance-theater/env": "workspace:*",
    "@compliance-theater/feature-flags": "workspace:*",
    "@compliance-theater/json-viewer": "workspace:*",
    "@compliance-theater/logger": "workspace:*",
    "@compliance-theater/nextjs": "workspace:*",
    "@compliance-theater/react": "workspace:*",
    "@compliance-theater/redis": "workspace:*",
    "@compliance-theater/send-api-request": "workspace:*",
    "@compliance-theater/themes": "workspace:*",
    "@compliance-theater/types": "workspace:*",
    "@compliance-theater/typescript": "workspace:*",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/api-logs": "0.57.2",
    "@redis/client": ">=5.5.6",
    "@semanticencoding/core": "workspace:*",
    "drizzle-orm": "^0.44.1",
    "got": "^14.4.9",
    "mitt": "^3.0.1",
    "pg": ">=8",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-native": "^0.84.0",
    "semanticencoding": "workspace:*",
    "zod": "3.25.76",
    "zodex": "^3.0.0"
  }
}
