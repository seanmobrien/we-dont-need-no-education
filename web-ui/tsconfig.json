{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "jsx": "react-jsx",
        "noEmit": false,
        "baseUrl": "../",
        "customConditions": [
            "workspace-source"
        ],
    },
    "files": [],
    "exclude": [
        "**/tests/**",
        "**/__tests__/**",
        "**/__mocks__/**",
        "**/dist/**",
        "**/.next/**",
        "**/.turbo/**",
        "**/packages/**",
        "**/submodules/**",
