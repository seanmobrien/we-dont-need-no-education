{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "./tsconfig.json",
    "./tsconfig.*.json",
    "./*.mjs",
    "./package.json"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!**/coverage/**",
        "!**/test-results/**",
        "!**/dist/**",
        "!**/.next/**",
        "!**/.yarn/install-state.gz",
        "!**/*.tsbuildinfo",
        "!**/tsconfig.tsbuildinfo",
        "!**/.turbo/**",
        "!**/.upstream/**",
        "!**/*.log",
        "!**/out/**",
        "!**/out/**",
        "!**/lcov-report/**"
      ],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "AUTH_*",
        "AZURE_*",
        "NEXT_*",
        "NODE_ENV",
        "YARN_IGNORE_PATH",
        "CRYPTO_*",
        "GOOGLE_*",
        "LOG_LEVEL_SERVER",
        "MEM0_*",
        "OPENAI_*",
        "OTEL_*",
        "REDIS_*",
        "DATABASE_URL",
        "WORKSPACE_SOURCE_IMPORTS"
      ]
    },
    "@compliance-theater/app#build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!**/coverage/**",
        "!**/test-results/**",
        "!**/dist/**",
        "!**/.next/**",
        "!**/.yarn/install-state.gz",
        "!**/*.tsbuildinfo",
        "!**/tsconfig.tsbuildinfo",
        "!**/.turbo/**",
        "!**/.upstream/**",
        "!**/*.log",
        "!**/out/**",
        "!**/out/**",
        "!**/lcov-report/**"
      ],
      "outputs": [],
      "env": [
        "AUTH_*",
        "AZURE_*",
        "NEXT_*",
        "NODE_ENV",
        "YARN_IGNORE_PATH",
        "CRYPTO_*",
        "GOOGLE_*",
        "LOG_LEVEL_SERVER",
        "MEM0_*",
        "OPENAI_*",
        "OTEL_*",
        "REDIS_*",
        "DATABASE_URL",
        "WORKSPACE_SOURCE_IMPORTS"
      ]
    },
    "@semanticencoding/monorepo#build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!**/coverage/**",
        "!**/test-results/**",
        "!**/dist/**",
        "!**/.next/**",
        "!**/.yarn/install-state.gz",
        "!**/*.tsbuildinfo",
        "!**/tsconfig.tsbuildinfo",
        "!**/.turbo/**",
        "!**/.upstream/**",
        "!**/*.log",
        "!**/out/**",
        "!**/out/**",
        "!**/lcov-report/**"
      ],
      "outputs": [],
      "env": [
        "AUTH_*",
        "AZURE_*",
        "NEXT_*",
        "NODE_ENV",
        "YARN_IGNORE_PATH",
        "CRYPTO_*",
        "GOOGLE_*",
        "LOG_LEVEL_SERVER",
        "MEM0_*",
        "OPENAI_*",
        "OTEL_*",
        "REDIS_*",
        "DATABASE_URL",
        "WORKSPACE_SOURCE_IMPORTS"
      ]
    },
    "build:typescript": {
      "dependsOn": ["^build:typescript"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!**/coverage/**",
        "!**/test-results/**",
        "!**/dist/**",
        "!**/.next/**",
        "!**/.yarn/install-state.gz",
        "!**/*.tsbuildinfo",
        "!**/tsconfig.tsbuildinfo",
        "!**/.turbo/**",
        "!**/.upstream/**",
        "!**/*.log",
        "!**/out/**",
        "!**/out/**",
        "!**/lcov-report/**"
      ],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "AUTH_*",
        "AZURE_*",
        "NEXT_*",
        "NODE_ENV",
        "YARN_IGNORE_PATH",
        "CRYPTO_*",
        "GOOGLE_*",
        "LOG_LEVEL_SERVER",
        "MEM0_*",
        "OPENAI_*",
        "OTEL_*",
        "REDIS_*",
        "DATABASE_URL",
        "WORKSPACE_SOURCE_IMPORTS"
      ]
    },
    "@compliance-theater/app#build:typescript": {
      "dependsOn": ["^build:typescript"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!**/coverage/**",
        "!**/test-results/**",
        "!**/dist/**",
        "!**/.next/**",
        "!**/.yarn/install-state.gz",
        "!**/*.tsbuildinfo",
        "!**/tsconfig.tsbuildinfo",
        "!**/.turbo/**",
        "!**/.upstream/**",
        "!**/*.log",
        "!**/out/**",
        "!**/out/**",
        "!**/lcov-report/**"
      ],
      "outputs": [],
      "env": [
        "AUTH_*",
        "AZURE_*",
        "NEXT_*",
        "NODE_ENV",
        "YARN_IGNORE_PATH",
        "CRYPTO_*",
        "GOOGLE_*",
        "LOG_LEVEL_SERVER",
        "MEM0_*",
        "OPENAI_*",
        "OTEL_*",
        "REDIS_*",
        "DATABASE_URL",
        "WORKSPACE_SOURCE_IMPORTS"
      ]
    },
    "@semanticencoding/monorepo#build:typescript": {
      "dependsOn": ["^build:typescript"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!**/coverage/**",
        "!**/test-results/**",
        "!**/dist/**",
        "!**/.next/**",
        "!**/.yarn/install-state.gz",
        "!**/*.tsbuildinfo",
        "!**/tsconfig.tsbuildinfo",
        "!**/.turbo/**",
        "!**/.upstream/**",
        "!**/*.log",
        "!**/out/**",
        "!**/out/**",
        "!**/lcov-report/**"
      ],
      "outputs": [],
      "env": [
        "AUTH_*",
        "AZURE_*",
        "NEXT_*",
        "NODE_ENV",
        "YARN_IGNORE_PATH",
        "CRYPTO_*",
        "GOOGLE_*",
        "LOG_LEVEL_SERVER",
        "MEM0_*",
        "OPENAI_*",
        "OTEL_*",
        "REDIS_*",
        "DATABASE_URL",
        "WORKSPACE_SOURCE_IMPORTS"
      ]
    },
    "build:publish": {
      "dependsOn": ["^build:publish"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!**/coverage/**",
        "!**/test-results/**",
        "!**/dist/**",
        "!**/.next/**",
        "!**/.yarn/install-state.gz",
        "!**/*.tsbuildinfo",
        "!**/tsconfig.tsbuildinfo",
        "!**/.turbo/**",
        "!**/.upstream/**",
        "!**/*.log",
        "!**/out/**",
        "!**/out/**",
        "!**/lcov-report/**"
      ],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "AUTH_*",
        "AZURE_*",
        "NEXT_*",
        "NODE_ENV",
        "YARN_IGNORE_PATH",
        "CRYPTO_*",
        "GOOGLE_*",
        "LOG_LEVEL_SERVER",
        "MEM0_*",
        "OPENAI_*",
        "OTEL_*",
        "REDIS_*",
        "DATABASE_URL",
        "WORKSPACE_SOURCE_IMPORTS"
      ]
    },
    "@semanticencoding/monorepo#build:publish": {
      "dependsOn": ["^build:publish"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!**/coverage/**",
        "!**/test-results/**",
        "!**/dist/**",
        "!**/.next/**",
        "!**/.yarn/install-state.gz",
        "!**/*.tsbuildinfo",
        "!**/tsconfig.tsbuildinfo",
        "!**/.turbo/**",
        "!**/.upstream/**",
        "!**/*.log",
        "!**/out/**",
        "!**/out/**",
        "!**/lcov-report/**"
      ],
      "outputs": [],
      "env": [
        "AUTH_*",
        "AZURE_*",
        "NEXT_*",
        "NODE_ENV",
        "YARN_IGNORE_PATH",
        "CRYPTO_*",
        "GOOGLE_*",
        "LOG_LEVEL_SERVER",
        "MEM0_*",
        "OPENAI_*",
        "OTEL_*",
        "REDIS_*",
        "DATABASE_URL",
        "WORKSPACE_SOURCE_IMPORTS"
      ]
    },

    "build:clean": {
      "dependsOn": ["^build:clean"],
      "cache": false,
      "persistent": false,
      "outputs": []
    },
    "dev": {
      "cache": false,
      "dependsOn": ["^dev"],
      "persistent": true
    },
    "debug": {
      "cache": false,
      "dependsOn": ["^debug"],
      "persistent": true
    },
    "add": {
      "dependsOn": ["^add"],
      "cache": false
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!**/coverage/**",
        "!**/test-results/**",
        "!**/dist/**",
        "!**/.next/**",
        "!**/.yarn/install-state.gz",
        "!**/*.tsbuildinfo",
        "!**/tsconfig.tsbuildinfo",
        "!**/.turbo/**",
        "!**/.upstream/**",
        "!**/*.log",
        "!**/out/**",
        "!**/out/**",
        "!**/lcov-report/**"
      ]
    },
    "test:unit": {
      "dependsOn": ["^test:unit"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!**/coverage/**",
        "!**/test-results/**",
        "!**/dist/**",
        "!**/.next/**",
        "!**/.yarn/install-state.gz",
        "!**/*.tsbuildinfo",
        "!**/tsconfig.tsbuildinfo",
        "!**/.turbo/**",
        "!**/.upstream/**",
        "!**/*.log",
        "!**/out/**",
        "!**/out/**",
        "!**/lcov-report/**"
      ],
      "outputs": []
    },
    "test:e2e": {
      "dependsOn": ["^test:e2e"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!**/coverage/**",
        "!**/test-results/**",
        "!**/dist/**",
        "!**/.next/**",
        "!**/.yarn/install-state.gz",
        "!**/*.tsbuildinfo",
        "!**/tsconfig.tsbuildinfo",
        "!**/.turbo/**",
        "!**/.upstream/**",
        "!**/*.log",
        "!**/out/**",
        "!**/out/**",
        "!**/lcov-report/**"
      ],
      "cache": false
    },
    "lint": {
      "dependsOn": ["^lint"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!**/coverage/**",
        "!**/test-results/**",
        "!**/dist/**",
        "!**/.next/**",
        "!**/.yarn/install-state.gz",
        "!**/*.tsbuildinfo",
        "!**/tsconfig.tsbuildinfo",
        "!**/.turbo/**",
        "!**/.upstream/**",
        "!**/*.log",
        "!**/out/**",
        "!**/out/**",
        "!**/lcov-report/**"
      ],
      "outputs": []
    }
  }
}
