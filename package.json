{
  "name": "compliance-theater-repo-root",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@4.12.0",
  "engines": {
    "node": ">=22.0.0",
    "yarn": ">=4.12.0"
  },
  "workspaces": [
    "web-ui",
    "web-ui/packages/*",
    "web-ui/submodules/json-viewer",
    "web-ui/submodules/json-viewer/docs",
    "web-ui/submodules/sce/packages/**/ts"
  ],
  "scripts": {
    "add": "yarn workspace compliance-theater add ",
    "preinstall": "node scripts/validate-yarn.js",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "release:version": "changeset version",
    "release:publish": "changeset publish",
    "dev": "yarn workspace @compliance-theater/app dev",
    "debug": "yarn workspace @compliance-theater/app debug",
    "build": "yarn workspace compliance-theater build",
    "build:typescript": "yarn workspace compliance-theater build:typescript",
    "build:publish": "yarn workspace compliance-theater build:publish",
    "build:clean": "yarn workspace compliance-theater build:clean",
    "test": "yarn workspace compliance-theater test",
    "test:coverage": "yarn workspace compliance-theater test:coverage",
    "test:fast": "yarn workspace compliance-theater test:fast",
    "test:unit": "yarn workspace compliance-theater test:unit",
    "test:e2e": "yarn workspace compliance-theater test:e2e",
    "lint": "yarn workspace compliance-theater lint",
    "ci:install": "yarn install",
    "ci:build": "yarn build",
    "ci:test": "yarn test",
    "vercel-build": "yarn run ci:build"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@jest/globals": "^30.0.5",
    "@types/node": "25.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "jest": "^30.0.5",
    "jest-environment-jsdom": "^30.0.5",
    "jest-mock-extended": "^4.0.0-beta1",
    "ts-jest": "^30.0.0",
    "ts-node": "^10.9.1",
    "turbo": "^2.8.3",
    "typescript": "^5.9.3"
  },
  "resolutions": {
    "@compliance-theater/json-viewer": "workspace:*",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-promise": "7.2.1",
    "jsx-ast-utils@npm:3.3.5": "patch:jsx-ast-utils@npm%3A3.3.5#./patches/jsx-ast-utils-npm-3.3.5.patch",
    "lodash-es@npm:^4.17.21": "npm:4.17.23",
    "@esbuild-kit/core-utils/esbuild": "^0.27.3",
    "drizzle-kit/esbuild": "^0.27.3",
    "vite/esbuild": "^0.27.3",
    "node-html-parser": "^7.0.2",
    "next": "^15.5.12",
    "@jest/globals": "^30.0.5",
    "jest": "^30.0.5",
    "ts-jest": "^29.4.6",
    "@types/node": "25.2.3",
    "tough-cookie": "^6.0.0",
    "@tanstack/react-query": "5.90.21",
    "@tanstack/react-query-devtools": "5.91.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-native": "0.84.0"
  },
  "overrides": {
    "uri-js": "npm:uri-js-replace",
    "psl": "npm:@imput/psl@2.0.4",
    "data-urls@3.*": {
      "whatwg-url": "12.0.1"
    },
    "jest-environment-jsdom": {
      "jsdom": {
        "whatwg-url": "12.0.1"
      }
    },
    "@compliance-theater/json-viewer": "workspace:*"
  }
}
